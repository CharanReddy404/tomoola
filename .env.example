# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/tomoola

# Redis (Required for OTP storage and caching)
REDIS_URL=redis://localhost:6379
# OR use separate host/port
# REDIS_HOST=localhost
# REDIS_PORT=6379

# Auth (REQUIRED - Generate a strong random secret)
JWT_SECRET=your-strong-jwt-secret-minimum-32-characters

# App
PORT=4000
FRONTEND_URL=http://localhost:3000
NODE_ENV=development

# Cloudflare R2
R2_ACCOUNT_ID=
R2_ACCESS_KEY=
R2_SECRET_KEY=
R2_BUCKET=tomoola-media
R2_PUBLIC_URL=

# WhatsApp (Meta Cloud API)
WHATSAPP_ENABLED=false
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# Email (SMTP)
EMAIL_ENABLED=false
EMAIL_FROM="ToMoola <no-reply@tomoola.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
